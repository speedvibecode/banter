{
  "name": "banter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:deploy": "prisma generate && node scripts/prepareMigrations.js && prisma migrate deploy && next build",
    "deploy:db": "prisma generate && node scripts/prepareMigrations.js && prisma migrate deploy",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "resolve-polls": "ts-node --transpile-only -r tsconfig-paths/register scripts/resolvePolls.ts",
    "seed": "ts-node --transpile-only -r tsconfig-paths/register scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.511.0",
    "next": "^14.2.25",
    "next-auth": "^4.24.11",
    "pino": "^9.6.0",
    "posthog-js": "^1.234.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.25",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "@next/eslint-plugin-next": {
      "glob": "^10.5.0"
    }
  }
}
